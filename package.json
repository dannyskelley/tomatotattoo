{
    "name": "starter-kit-v4",
    "version": "1.0.0",
    "description": "",
    "main": "index.js",
    "scripts": {
        "watch:sass": "sass --watch src/assets/sass:./src/assets/css",
        "build:sass": "./node_modules/.bin/sass src/assets/sass:./src/assets/css",
        "watch:eleventy": "cross-env ELEVENTY_ENV=DEV eleventy --serve",
        "build:eleventy": "cross-env ELEVENTY_ENV=PROD ./node_modules/.bin/eleventy",
        "start": "del-cli ./public --force && npm-run-all --parallel watch:sass watch:eleventy",
        "build": "npm run build:sass && npm run build:eleventy"
    },
    "dependencies": {
        "@11ty/eleventy": "^3.1.6",
        "@11ty/eleventy-navigation": "^0.3.5",
        "@quasibit/eleventy-plugin-sitemap": "^2.2.0",
        "@sherby/eleventy-plugin-files-minifier": "^1.1.1",
        "cross-env": "^7.0.3",
        "del-cli": "^5.0.0",
        "esbuild": "^0.21.4",
        "npm-run-all": "^4.1.5",
        "sass": "^1.77.4"
    }
}
